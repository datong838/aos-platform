# AOS · 大模型（Agnes OpenAI 兼容）— 复制为 .env 后填写；勿提交真实密钥
# 路径：aos-platform/.env
# 加载方：aos-api（llm_gateway）· deploy/dev LiteLLM 形边车

# --- Agnes（你来填）---
AGNES_API_KEY=
AGNES_BASE_URL=
AGNES_TEXT_MODEL=
AGNES_IMAGE_MODEL=

# --- 可选：边车 / 门禁（Dev 默认即可）---
# AOS_LITELLM_URL=http://127.0.0.1:4000
# AOS_LITELLM_FALLBACK=mock
# AOS_LLM_MASTER_KEY=aos_dev_litellm_master
# AOS_LLM_API_KEY_REF=vault:secret/data/aos/llm#agnes
# AOS_DATABASE_URL=postgresql://aos_app:aos_dev_only_change_me@127.0.0.1:5433/aos_meta

# --- T4.2 MinIO / S3 兼容（密钥见 deploy/dev/.secrets.env）---
# AOS_S3_ENDPOINT=http://127.0.0.1:9000
# AOS_WSL_IP=
# AOS_S3_BUCKET=aos-media
# AOS_S3_DISABLED=0

# --- T4.6 MySQL（Dev compose 映射 3307；密钥见 .secrets.env）---
# AOS_MYSQL_HOST=
# AOS_MYSQL_PORT=3307
# AOS_MYSQL_USER=aos_src
# AOS_MYSQL_PASSWORD=
# AOS_MYSQL_DATABASE=aos_src
# AOS_MYSQL_DISABLED=0

# --- TX.3 OIDC / Dev JWT / Dev Keycloak (profile oidc) ---
# AOS_AUTH_ALLOW_DEV=1
# AOS_OIDC_ISSUER=http://aos-dev-oidc
# AOS_OIDC_AUDIENCE=aos-api
# AOS_OIDC_DEV_SECRET=
# AOS_OIDC_JWKS_URL=
# AOS_OIDC_TOKEN_URL=
# AOS_OIDC_CLIENT_ID=aos-api
# AOS_OIDC_CLIENT_ID_REF=vault:secret/data/aos/oidc#client_id

# Dev Keycloak (optional):
#   docker compose -f deploy/dev/docker-compose.yml --profile oidc up -d aos-dev-keycloak
#   AOS_OIDC_ISSUER=http://127.0.0.1:8083/realms/aos
#   AOS_OIDC_AUDIENCE=aos-api
#   AOS_OIDC_JWKS_URL=http://127.0.0.1:8083/realms/aos/protocol/openid-connect/certs
#   AOS_OIDC_TOKEN_URL=http://127.0.0.1:8083/realms/aos/protocol/openid-connect/token
#   .\scripts\ci\probe-keycloak-oidc.ps1
#
# Dev HA Keycloak (scheme 57; mutually exclusive with profile oidc on :8083):
#   docker compose -f deploy/dev/docker-compose.yml --profile oidc-ha up -d
#   AOS_OIDC_ISSUER=http://127.0.0.1:8083/realms/aos
#   AOS_OIDC_ISSUERS=http://127.0.0.1:8083/realms/aos
#   AOS_OIDC_JWKS_URLS=http://127.0.0.1:8083/realms/aos/protocol/openid-connect/certs
#   AOS_OIDC_TOKEN_URL=http://127.0.0.1:8083/realms/aos/protocol/openid-connect/token
#   .\scripts\ci\probe-keycloak-ha.ps1
#
# Production IdP (scheme 60 handbook — customer IdP, no AOS-bundled KC):
#   AOS_AUTH_ALLOW_DEV=0
#   AOS_OIDC_ISSUER=https://idp.example.com/realms/aos
#   AOS_OIDC_AUDIENCE=aos-api
#   AOS_OIDC_JWKS_URL=https://idp.example.com/realms/aos/protocol/openid-connect/certs
#   .\scripts\ci\probe-prod-idp.ps1 -Issuer ... -JwksUrl ... [-AccessToken ...]

# --- T5.6 Ferry MVP (HMAC; change in prod) ---
# AOS_FERRY_HMAC_SECRET=aos_dev_ferry_hmac_change_me
# AOS_FERRY_IMAGES=postgres:16-alpine,minio/minio:RELEASE.2025-04-22T22-12-26Z
# AOS_FERRY_SKOPEO=0
# AOS_FERRY_SKOPEO_REFS=alpine:latest
# AOS_FERRY_SKOPEO_IMAGE=quay.io/skopeo/stable:v1.16.1
# AOS_FERRY_SKOPEO_TIMEOUT=900
# AOS_FERRY_SKOPEO_MAX_MIB=64
# AOS_FERRY_IMAGES_MANIFEST=deploy/ferry/customer-images.example.json
# AOS_FERRY_COSIGN_KEY=
# AOS_FERRY_COSIGN_PUB=
# AOS_FERRY_COSIGN_REQUIRED=0
# AOS_FERRY_COSIGN_IMAGE=ghcr.io/sigstore/cosign/cosign:v2.4.1
# .\scripts\ci\probe-ferry-skopeo.ps1
# Large images onsite (scheme 62 — do not base64 via API):
#   .\scripts\ci\probe-ferry-large-images.ps1
#   .\scripts\ci\pack-ferry-images-onsite.ps1 -Manifest deploy\ferry\customer-images.example.json
# Real cosign keychain (scheme 64; Full Channel still deferred):
#   .\scripts\ci\gen-ferry-cosign-keys.ps1
#   .\scripts\ci\probe-ferry-cosign.ps1

# --- TX.4 OpenFGA facade (optional remote; default = local PG tuples) ---
# Model aos-prod-v1 (scheme 61): org/project/object/marking — deploy/dev/openfga/model.fga
# AOS_OPENFGA_API_URL=
# AOS_OPENFGA_STORE_ID=aos
# AOS_OPENFGA_STRICT=0
# AOS_AUTHZ_MARKING_BEARER=1
#
# Dev OpenFGA sidecar (schemes 58/61/63):
#   docker compose -f deploy/dev/docker-compose.yml --profile openfga up -d
#   .\scripts\ci\bootstrap-openfga.ps1
#   # merges hint into deploy/dev/openfga-store.env — copy AOS_OPENFGA_* into .env
#   .\scripts\ci\probe-openfga.ps1
#   GET /v1/authz/model
