# 161 · 客户生产 IdP 验收（微商城案例）· 示例环境
# 复制为 customer-idp.mall.env（勿提交含密钥的副本）后填写。
# 用法：
#   set -a && source deploy/dev/customer-idp.mall.env && set +a
#   bash scripts/ci/accept-customer-idp.sh
#
# 诚实：无 token 时脚本只验 discovery/JWKS；有 token 才验 /v1/me。

# 案例名（写入验收报告）
AOS_IDP_CASE_NAME=mall-online

# 客户 OIDC（与 JWT iss / JWKS 一致）
AOS_OIDC_ISSUER=https://idp.example.com/realms/mall
AOS_OIDC_JWKS_URL=https://idp.example.com/realms/mall/protocol/openid-connect/certs
AOS_OIDC_AUDIENCE=aos-api

# aos-api 基址（客户现场或本机已配生产同构 env 的实例）
AOS_API_BASE=http://127.0.0.1:8080

# 样例 access_token（优先）；或指向文件（单行 JWT，勿入库）
# AOS_PROBE_TOKEN=
# AOS_PROBE_TOKEN_FILE=/absolute/path/to/sample.jwt

# 可选 claim 期望（探针只打印 /v1/me；人工对照）
# AOS_EXPECT_ORG_ID=
# AOS_EXPECT_PROJECT_ID=
