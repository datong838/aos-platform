# AOS OpenFGA model — scheme 61 (aos-prod-v1)
# Source of truth for humans; JSON posted by bootstrap-openfga.ps1

model
  schema 1.1

type user

type organization
  relations
    define member: [user]

type project
  relations
    define parent: [organization]
    define member: [user] or member from parent

type object
  relations
    define owner: [user]
    define editor: [user] or owner
    define viewer: [user] or editor

type marking
  relations
    define bearer: [user]
