{
  "id": "ollama",
  "name": "Ollama",
  "nameZh": "Ollama（本地）",
  "description": "本机免费本地模型",
  "tier": "free",
  "modalities": [
    "text"
  ],
  "capabilities": [
    "llm",
    "chat"
  ],
  "formFamily": "local",
  "defaultModels": [
    "llama3.2"
  ],
  "litellmPrefix": "ollama/",
  "version": "0.1.0",
  "author": "aos",
  "configSchema": {
    "type": "object",
    "properties": {
      "apiKeyRef": {
        "type": "string",
        "description": "Vault 凭据引用"
      },
      "models": {
        "type": "array",
        "items": {
          "type": "string"
        },
        "default": [
          "llama3.2"
        ]
      },
      "baseUrl": {
        "type": "string",
        "default": "http://127.0.0.1:11434"
      },
      "modelPath": {
        "type": "string"
      },
      "warmup": {
        "type": "boolean",
        "default": true
      }
    }
  }
}
